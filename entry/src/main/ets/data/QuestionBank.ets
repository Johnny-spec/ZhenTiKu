export function getPapers(gradeId: string, subjectId: string): Paper[] {
  return PAPERS.filter((paper: Paper) => paper.grade === gradeId && paper.subject === subjectId);
}

export function getPaper(paperId: string): Paper | undefined {
  return PAPERS.find((paper: Paper) => paper.id === paperId);
}

export function searchQuestions(keyword: string): Question[] {
  const normalizedKeyword: string = keyword.trim().toLowerCase();
  const result: Question[] = [];
  if (normalizedKeyword.length === 0) {
    return result;
  }
  PAPERS.forEach((paper: Paper) => {
    paper.questions.forEach((question: Question) => {
      const stemText: string = question.stem.toLowerCase();
      const knowledgeText: string = question.knowledge === undefined ? '' : question.knowledge.toLowerCase();
      if (stemText.indexOf(normalizedKeyword) >= 0 || knowledgeText.indexOf(normalizedKeyword) >= 0) {
        result.push(question);
      }
    });
  });
  return result;
}

export function getAllSubjectsForGrade(gradeId: string): string[] {
  const subjects: string[] = [];
  PAPERS.forEach((paper: Paper) => {
    if (paper.grade === gradeId && subjects.indexOf(paper.subject) < 0) {
      subjects.push(paper.subject);
    }
  });
  return subjects;
}
